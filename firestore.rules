rules_version = '2';

// ⚠️⚠️⚠️  WARNING — FULLY OPEN RULES  ⚠️⚠️⚠️
//
// These rules allow ANYONE on the internet to READ, WRITE, UPDATE and DELETE
// every document in every collection of this Firestore database. No auth
// required. This is intended ONLY for quick testing / bring-up while you
// diagnose read/write issues.
//
// 🚨 Risks while these are live:
//   • Any visitor can wipe your entire `news`, `comments`, `ads` etc.
//   • Any visitor can post spam / malicious content.
//   • Billing can spike from abuse (reads are metered).
//
// 🛡️  Tighten these as soon as things work:
//   • `news`, `ads`, `logos`: keep `read:true`, change write to
//     `request.auth != null` (admin-login required).
//   • Everything else: change to `request.auth != null`.
//   • See the earlier, safer version of this file in the repo history
//     (commit 4b455da) for a good starting template.
//
// DEPLOY:
//   https://console.firebase.google.com/project/kwt-news/firestore/rules
//   → paste this entire file → Publish.

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
