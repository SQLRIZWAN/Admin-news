rules_version = '2';

// Firestore security rules for the KWT News project.
//
// ⚠️  DEPLOY THESE RULES:
//   Option A — Firebase Console:
//     1. Open https://console.firebase.google.com/project/kwt-news/firestore/rules
//     2. Replace the existing rules with the contents of this file.
//     3. Click "Publish".
//
//   Option B — Firebase CLI (if installed):
//     firebase deploy --only firestore:rules
//
// Admin SDK (used by the Python automation pipeline) BYPASSES these rules — so
// pipeline writes always succeed regardless of what's here. These rules govern
// the browser-based admin app and the public news website.

service cloud.firestore {
  match /databases/{database}/documents {

    // News articles — public read (website), authenticated write (admin).
    match /news/{id} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // Ads — public read, authenticated write.
    match /ads/{id} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // Source logos — public read, authenticated write.
    match /logos/{id} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // Comments — public read + public create (end users post comments),
    // authenticated delete (admin moderation).
    match /comments/{id} {
      allow read, create: if true;
      allow update, delete: if request.auth != null;
    }

    // Users — authenticated only (admin lists + blocks users).
    match /users/{id} {
      allow read, write: if request.auth != null;
    }

    // Automation pipeline collections — authenticated admin read/write.
    // The pipeline uses the Admin SDK which bypasses these rules.
    match /automation_config/{id} { allow read, write: if request.auth != null; }
    match /automation_logs/{id}   { allow read, write: if request.auth != null; }
    match /pipeline_locks/{id}    { allow read, write: if request.auth != null; }

    // Social media collections — authenticated admin only.
    match /social_accounts/{id}     { allow read, write: if request.auth != null; }
    match /social_media_queue/{id}  { allow read, write: if request.auth != null; }

    // Push notifications — users can register their own token (create),
    // only admin reads the full list or deletes.
    match /fcm_tokens/{id} {
      allow read, delete: if request.auth != null;
      allow create, update: if true;
    }
    match /notification_history/{id} {
      allow read, write: if request.auth != null;
    }

    // Admin diagnostic probe (temporary write+delete from the admin panel).
    match /_diagnostic/{id} {
      allow read, write: if request.auth != null;
    }

    // Fallback: deny everything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
