{
  "name": "kwt-news-admin",
  "version": "1.0.0",
  "description": "KWT News admin panel — frontend (GitHub Pages) + automation pipeline",
  "private": true,
  "scripts": {
    "build": "babel app_jsx.jsx --out-file app.compiled.js",
    "deploy:indexes": "npx --yes firebase-tools@13 deploy --only firestore:indexes --project kwt-news --non-interactive",
    "deploy:rules":   "npx --yes firebase-tools@13 deploy --only firestore:rules   --project kwt-news --non-interactive"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5"
  }
}
