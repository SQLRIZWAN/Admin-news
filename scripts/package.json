{
  "name": "kwt-news-scheduler",
  "version": "1.0.0",
  "description": "Automated news posting scheduler for KWT News",
  "type": "module",
  "main": "post-news.js",
  "scripts": {
    "post": "node post-news.js",
    "backfill:timestamps": "node backfill-timestamps.js",
    "deploy:indexes": "npx --yes firebase-tools@13 deploy --only firestore:indexes --project kwt-news --non-interactive",
    "deploy:rules":   "npx --yes firebase-tools@13 deploy --only firestore:rules   --project kwt-news --non-interactive",
    "deploy:hosting": "npx --yes firebase-tools@13 deploy --only hosting --project kwt-news --non-interactive",
    "deploy:all":     "npx --yes firebase-tools@13 deploy --project kwt-news --non-interactive"
  },
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "node-fetch": "^3.3.2"
  },
  "engines": {
    "node": ">=18"
  }
}
